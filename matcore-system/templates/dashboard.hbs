<section class="matcore-shell">
  <header class="matcore-header">
    <div>
      <h1>MatCore System</h1>
      <p>Console visuelle de l’écosystème Foundry.</p>
    </div>

    <button type="button" class="matcore-button" data-action="refresh">
      Rafraîchir
    </button>
  </header>

    <nav class="matcore-tab-overview">
    <button class="matcore-tab-card {{#if (eq activeTab 'home')}}active{{/if}}" data-tab="home">
        <span class="matcore-tab-close">×</span>
        <strong>Accueil</strong>
        <small>État général</small>
    </button>

    <button class="matcore-tab-card {{#if (eq activeTab 'hero')}}active{{/if}}" data-tab="hero">
        <span class="matcore-tab-close">×</span>
        <strong>Hero Stats</strong>
        <small>Dés & héroïsme</small>
    </button>

    <button class="matcore-tab-card {{#if (eq activeTab 'vitality')}}active{{/if}}" data-tab="vitality">
        <span class="matcore-tab-close">×</span>
        <strong>Vitality Network</strong>
        <small>Ressources mystiques</small>
    </button>

    <button class="matcore-tab-card {{#if (eq activeTab 'combat')}}active{{/if}}" data-tab="combat">
        <span class="matcore-tab-close">×</span>
        <strong>Combat Log</strong>
        <small>Archives de combat</small>
    </button>

    <button class="matcore-tab-card {{#if (eq activeTab 'events')}}active{{/if}}" data-tab="events">
        <span class="matcore-tab-close">×</span>
        <strong>Event Forge</strong>
        <small>Événements</small>
    </button>

    <button class="matcore-tab-card {{#if (eq activeTab 'gaia')}}active{{/if}}" data-tab="gaia">
        <span class="matcore-tab-close">×</span>
        <strong>Gaïa</strong>
        <small>Exploration</small>
    </button>
    <button class="matcore-tab-card {{#if (eq activeTab 'small-tools')}}active{{/if}}" data-tab="small-tools">
      <span class="matcore-tab-close">×</span>
      <strong>Small Tools</strong>
      <small>Réparation & tests</small>
    </button>
    </nav>

  {{#if (eq activeTab 'small-tools')}}
    <section class="matcore-panel">
      <div class="matcore-panel-header">
        <div>
          <h2>PF2e Small Tools</h2>
          <p class="matcore-lead">
            Petits outils de table : réparation guidée d’objets et tests rapides.
          </p>
        </div>
      </div>

      {{#if smallTools.available}}
        <div class="matcore-stats">
          <div>
            <span>Réparation</span>
            <strong>{{#if smallTools.canRepair}}Active{{else}}Indisponible{{/if}}</strong>
          </div>

          <div>
            <span>Tests rapides</span>
            <strong>{{#if smallTools.canCreateQuickTest}}MJ{{else}}Verrouillé{{/if}}</strong>
          </div>
        </div>

        <div class="matcore-actions">
          <button
            type="button"
            data-module="pf2e-small-tools"
            data-action="openRepairDialog">
            Réparer un objet
          </button>

          {{#if isGM}}
            <button
              type="button"
              data-module="pf2e-small-tools"
              data-action="openQuickTestDialog">
              Générer un test rapide
            </button>
          {{/if}}
        </div>
      {{else}}
        <p>PF2e Small Tools n’est pas actif ou n’expose pas encore son API.</p>
      {{/if}}
    </section>
  {{/if}}
  {{#if (eq activeTab 'home')}}
    <section class="matcore-panel">
      <h2>État de l’écosystème</h2>
      <p class="matcore-lead">
        {{activeCount}} module(s) actif(s) sur {{totalCount}} surveillé(s).
      </p>

      <div class="matcore-grid">
        {{#each modules}}
          <article class="matcore-card {{#if active}}active{{else}}inactive{{/if}}">
            <div class="matcore-card-title">
              <span>{{label}}</span>
              {{#if active}}
                <strong class="matcore-status ok">Actif</strong>
              {{else}}
                <strong class="matcore-status ko">Inactif</strong>
              {{/if}}
            </div>
            <p>{{type}} · v{{version}}</p>
          </article>
        {{/each}}
      </div>
    </section>
  {{/if}}

    {{#if (eq activeTab 'hero')}}
    <section class="matcore-panel">
        <div class="matcore-panel-header">
        <div>
            <h2>Hero Stats</h2>
            <p class="matcore-lead">Observatoire des jets, de la chance et des braises héroïques.</p>
        </div>
        </div>

        {{#if heroStats.available}}
        <div class="matcore-stats">
            <div><span>Jets</span><strong>{{heroStats.totalRolls}}</strong></div>
            <div><span>Taux de réussite</span><strong>{{heroStats.successRate}}%</strong></div>
            <div><span>20 naturels</span><strong>{{heroStats.natural20}}</strong></div>
            <div><span>1 naturels</span><strong>{{heroStats.natural1}}</strong></div>
            <div><span>Critiques</span><strong>{{heroStats.criticalSuccesses}}</strong></div>
            <div><span>Échecs critiques</span><strong>{{heroStats.criticalFailures}}</strong></div>
            <div><span>Héroïsme gagné</span><strong>{{heroStats.heroGained}}</strong></div>
            <div><span>Héroïsme dépensé</span><strong>{{heroStats.heroUsed}}</strong></div>
        </div>

        <div class="matcore-two-columns">
            <article class="matcore-card">
            <h3>Astres favorables</h3>
            {{#if heroStats.bestActor}}
                <p><strong>{{heroStats.bestActor.name}}</strong></p>
                <p>D20 moyen : <strong>{{heroStats.bestActor.averageD20}}</strong></p>
            {{else}}
                <p>Aucun jet enregistré.</p>
            {{/if}}
            </article>

            <article class="matcore-card">
            <h3>Nuages persistants</h3>
            {{#if heroStats.worstActor}}
                <p><strong>{{heroStats.worstActor.name}}</strong></p>
                <p>D20 moyen : <strong>{{heroStats.worstActor.averageD20}}</strong></p>
            {{else}}
                <p>Aucun jet enregistré.</p>
            {{/if}}
            </article>
        </div>

        <h3 class="matcore-section-title">Personnages</h3>

        {{#if heroStats.actors.length}}
            <div class="matcore-table">
            <div class="matcore-table-row header">
                <span>Personnage</span>
                <span>Jets</span>
                <span>Moy.</span>
                <span>Réussite</span>
                <span>20</span>
                <span>1</span>
            </div>

            {{#each heroStats.actors}}
                <div class="matcore-table-row">
                <span>{{name}}</span>
                <span>{{totalRolls}}</span>
                <span>{{averageD20}}</span>
                <span>{{successRate}}%</span>
                <span>{{natural20}}</span>
                <span>{{natural1}}</span>
                </div>
            {{/each}}
            </div>
        {{else}}
            <p>Aucun personnage enregistré dans les statistiques.</p>
        {{/if}}

        {{#if isGM}}
        <div class="matcore-actions">
            <button type="button" data-action="give-hero-point-party">Donner 1 point au groupe</button>
            <button type="button" data-action="reset-hero-stats">Reset Hero Stats</button>
        </div>
        {{/if}}
        {{else}}
        <p>Hero Stats n’est pas actif ou n’expose pas encore son API.</p>
        {{/if}}
    </section>
    {{/if}}

  {{#if (eq activeTab 'vitality')}}
    <section class="matcore-panel">
        <h2>Vitality Network</h2>
        <p class="matcore-lead">Flux vital des Mystics connectés au réseau.</p>

        {{#if vitalityActors.length}}
        <div class="matcore-vn-grid">
            {{#each vitalityActors}}
            <article class="matcore-vn-card">
                <div class="matcore-vn-head">
                <strong>{{name}}</strong>
                <span>{{value}} / {{max}}</span>
                </div>

                <div class="matcore-vn-bar">
                <div class="matcore-vn-fill" style="width: {{percent}}%;"></div>
                </div>

                <small>{{percent}}% de réserve</small>

                {{#if canUseAbilities}}
                <div class="matcore-actions">
                    <button type="button" data-action="vn-transfer" data-actor-id="{{id}}">
                    Transfer Vitality
                    </button>
                </div>
                {{/if}}

                {{#if canAdmin}}
                <div class="matcore-actions matcore-admin-actions">
                    <button type="button" data-action="vn-recharge" data-actor-id="{{id}}">
                    Recharger
                    </button>

                    <button type="button" data-action="vn-empty" data-actor-id="{{id}}">
                    Vider
                    </button>
                </div>
                {{/if}}
            </article>
            {{/each}}
        </div>
        {{else}}
        <p>Aucun Mystic avec Vitality Network détecté.</p>
        {{/if}}
    </section>
    {{/if}}

  {{#if (eq activeTab 'combat')}}
    <section class="matcore-panel">
      <div class="matcore-panel-header">
        <div>
          <h2>Combat Log</h2>
          <p class="matcore-lead">
            Lecture rapide des archives de bataille.
          </p>
        </div>
      </div>

      {{#if combatLog.available}}
        <div class="matcore-stats">
          <div>
            <span>Journal</span>
            <strong>{{combatLog.journalName}}</strong>
          </div>

          <div>
            <span>Pages archivées</span>
            <strong>{{combatLog.pageCount}}</strong>
          </div>

          <div>
            <span>Combats en mémoire</span>
            <strong>{{combatLog.activeCombatLogCount}}</strong>
          </div>
        </div>

        {{#if combatLog.pages.length}}
          <div class="form-group">
            <label>Archive à consulter</label>
            <select data-action="select-combat-log-page">
              {{#each combatLog.pages}}
                <option value="{{id}}" {{#if (eq id ../selectedCombatLogPage.id)}}selected{{/if}}>
                  {{name}}
                </option>
              {{/each}}
            </select>
          </div>

          <article class="matcore-combat-log-preview">
            <h3>{{selectedCombatLogPage.name}}</h3>
            <div class="matcore-journal-content">
              {{{selectedCombatLogPage.content}}}
            </div>
          </article>
        {{else}}
          <p>Aucune archive de combat dans le journal pour l’instant.</p>
        {{/if}}

        {{#if combatLog.canOpenJournal}}
          <div class="matcore-actions">
            <button
              type="button"
              data-module="log-semi-auto"
              data-action="openCombatJournal">
              Ouvrir le journal Foundry
            </button>
          </div>
        {{/if}}
      {{else}}
        <p>Combat Log n’est pas actif ou n’expose pas encore ses archives.</p>
      {{/if}}
    </section>
  {{/if}}

  {{#if (eq activeTab 'events')}}
    <section class="matcore-panel">
      <div class="matcore-panel-header">
        <div>
          <h2>Event Forge</h2>
          <p class="matcore-lead">
            Création d’événements avec test de compétence, fluff et journalisation.
          </p>
        </div>
      </div>

      {{#if eventForge.available}}
        <div class="matcore-stats">
          <div>
            <span>Interface</span>
            <strong>Active</strong>
          </div>

          <div>
            <span>Création</span>
            <strong>{{#if eventForge.canCreateEvent}}MJ{{else}}Verrouillée{{/if}}</strong>
          </div>
        </div>

        {{#if isGM}}
          <div class="matcore-actions">
            <button
              type="button"
              data-module="event-forge"
              data-action="openEventForge">
              Créer un événement
            </button>
          </div>
        {{/if}}
      {{else}}
        <p>Event Forge n’est pas actif ou n’expose pas encore son API.</p>
      {{/if}}
    </section>
  {{/if}}

  {{#if (eq activeTab 'gaia')}}
    <section class="matcore-panel">
      <div class="matcore-panel-header">
        <div>
          <h2>Gaïa Exploration Tools</h2>
          <p class="matcore-lead">
            Console d’exploration, curiosités, ressources et traces de factions.
          </p>
        </div>
      </div>

      {{#if gaia.available}}
        <div class="matcore-stats">
          <div>
            <span>Entrées</span>
            <strong>{{gaia.totalEntries}}</strong>
          </div>

          <div>
            <span>Entrées personnalisées</span>
            <strong>{{gaia.customEntriesCount}}</strong>
          </div>

          <div>
            <span>Entrées retirées</span>
            <strong>{{gaia.excludedEntriesCount}}</strong>
          </div>
        </div>

        {{#if isGM}}
          <div class="matcore-actions">
            <button
              type="button"
              data-module="gaia-exploration-tools"
              data-action="openRollDialog">
              Tirage aléatoire
            </button>

            <button
              type="button"
              data-module="gaia-exploration-tools"
              data-action="openEntryPickerDialog">
              Lancer une entrée
            </button>

            <button
              type="button"
              data-module="gaia-exploration-tools"
              data-action="openEntryDialog">
              Ajouter une entrée
            </button>

            <button
              type="button"
              data-module="gaia-exploration-tools"
              data-action="listBiomes">
              Lister les biomes
            </button>
          </div>
        {{/if}}
      {{else}}
        <p>Gaïa Exploration Tools n’est pas actif ou n’expose pas encore son API.</p>
      {{/if}}
    </section>
  {{/if}}
</section>