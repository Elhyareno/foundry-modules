<section class="matcore-shell">
  <header class="matcore-header">
    <div>
      <h1>MatCore System</h1>
      <p>Console visuelle de l’écosystème Foundry.</p>
    </div>

    <button type="button" class="matcore-button" data-action="refresh">
      Rafraîchir
    </button>
  </header>

    <nav class="matcore-tab-overview">
    <button class="matcore-tab-card {{#if (eq activeTab 'home')}}active{{/if}}" data-tab="home">
        <span class="matcore-tab-close">×</span>
        <strong>Accueil</strong>
        <small>État général</small>
    </button>

    <button class="matcore-tab-card {{#if (eq activeTab 'hero')}}active{{/if}}" data-tab="hero">
        <span class="matcore-tab-close">×</span>
        <strong>Hero Stats</strong>
        <small>Dés & héroïsme</small>
    </button>

    <button class="matcore-tab-card {{#if (eq activeTab 'vitality')}}active{{/if}}" data-tab="vitality">
        <span class="matcore-tab-close">×</span>
        <strong>Vitality Network</strong>
        <small>Ressources mystiques</small>
    </button>

    <button class="matcore-tab-card {{#if (eq activeTab 'combat')}}active{{/if}}" data-tab="combat">
        <span class="matcore-tab-close">×</span>
        <strong>Combat Log</strong>
        <small>Archives de combat</small>
    </button>

    <button class="matcore-tab-card {{#if (eq activeTab 'events')}}active{{/if}}" data-tab="events">
        <span class="matcore-tab-close">×</span>
        <strong>Event Forge</strong>
        <small>Événements</small>
    </button>

    <button class="matcore-tab-card {{#if (eq activeTab 'gaia')}}active{{/if}}" data-tab="gaia">
        <span class="matcore-tab-close">×</span>
        <strong>Gaïa</strong>
        <small>Exploration</small>
    </button>
    </nav>

  {{#if (eq activeTab 'home')}}
    <section class="matcore-panel">
      <h2>État de l’écosystème</h2>
      <p class="matcore-lead">
        {{activeCount}} module(s) actif(s) sur {{totalCount}} surveillé(s).
      </p>

      <div class="matcore-grid">
        {{#each modules}}
          <article class="matcore-card {{#if active}}active{{else}}inactive{{/if}}">
            <div class="matcore-card-title">
              <span>{{label}}</span>
              {{#if active}}
                <strong class="matcore-status ok">Actif</strong>
              {{else}}
                <strong class="matcore-status ko">Inactif</strong>
              {{/if}}
            </div>
            <p>{{type}} · v{{version}}</p>
          </article>
        {{/each}}
      </div>
    </section>
  {{/if}}

    {{#if (eq activeTab 'hero')}}
    <section class="matcore-panel">
        <div class="matcore-panel-header">
        <div>
            <h2>Hero Stats</h2>
            <p class="matcore-lead">Observatoire des jets, de la chance et des braises héroïques.</p>
        </div>
        </div>

        {{#if heroStats.available}}
        <div class="matcore-stats">
            <div><span>Jets</span><strong>{{heroStats.totalRolls}}</strong></div>
            <div><span>Taux de réussite</span><strong>{{heroStats.successRate}}%</strong></div>
            <div><span>20 naturels</span><strong>{{heroStats.natural20}}</strong></div>
            <div><span>1 naturels</span><strong>{{heroStats.natural1}}</strong></div>
            <div><span>Critiques</span><strong>{{heroStats.criticalSuccesses}}</strong></div>
            <div><span>Échecs critiques</span><strong>{{heroStats.criticalFailures}}</strong></div>
            <div><span>Héroïsme gagné</span><strong>{{heroStats.heroGained}}</strong></div>
            <div><span>Héroïsme dépensé</span><strong>{{heroStats.heroUsed}}</strong></div>
        </div>

        <div class="matcore-two-columns">
            <article class="matcore-card">
            <h3>Astres favorables</h3>
            {{#if heroStats.bestActor}}
                <p><strong>{{heroStats.bestActor.name}}</strong></p>
                <p>D20 moyen : <strong>{{heroStats.bestActor.averageD20}}</strong></p>
            {{else}}
                <p>Aucun jet enregistré.</p>
            {{/if}}
            </article>

            <article class="matcore-card">
            <h3>Nuages persistants</h3>
            {{#if heroStats.worstActor}}
                <p><strong>{{heroStats.worstActor.name}}</strong></p>
                <p>D20 moyen : <strong>{{heroStats.worstActor.averageD20}}</strong></p>
            {{else}}
                <p>Aucun jet enregistré.</p>
            {{/if}}
            </article>
        </div>

        <h3 class="matcore-section-title">Personnages</h3>

        {{#if heroStats.actors.length}}
            <div class="matcore-table">
            <div class="matcore-table-row header">
                <span>Personnage</span>
                <span>Jets</span>
                <span>Moy.</span>
                <span>Réussite</span>
                <span>20</span>
                <span>1</span>
            </div>

            {{#each heroStats.actors}}
                <div class="matcore-table-row">
                <span>{{name}}</span>
                <span>{{totalRolls}}</span>
                <span>{{averageD20}}</span>
                <span>{{successRate}}%</span>
                <span>{{natural20}}</span>
                <span>{{natural1}}</span>
                </div>
            {{/each}}
            </div>
        {{else}}
            <p>Aucun personnage enregistré dans les statistiques.</p>
        {{/if}}

        {{#if isGM}}
        <div class="matcore-actions">
            <button type="button" data-action="give-hero-point-party">Donner 1 point au groupe</button>
            <button type="button" data-action="reset-hero-stats">Reset Hero Stats</button>
        </div>
        {{/if}}
        {{else}}
        <p>Hero Stats n’est pas actif ou n’expose pas encore son API.</p>
        {{/if}}
    </section>
    {{/if}}

  {{#if (eq activeTab 'vitality')}}
    <section class="matcore-panel">
      <h2>Vitality Network</h2>

      {{#if vitalityActors.length}}
        <div class="matcore-list">
          {{#each vitalityActors}}
            <article class="matcore-line">
              <strong>{{name}}</strong>
              <span>{{value}} / {{max}}</span>
            </article>
          {{/each}}
        </div>
      {{else}}
        <p>Aucun Mystic avec Vitality Network détecté.</p>
      {{/if}}
    </section>
  {{/if}}

  {{#if (eq activeTab 'combat')}}
    <section class="matcore-panel">
      <h2>Combat Log</h2>
      <p>Vue prête pour les derniers combats, les résumés et l’accès au journal.</p>
    </section>
  {{/if}}

  {{#if (eq activeTab 'events')}}
    <section class="matcore-panel">
      <h2>Event Forge</h2>
      <p>Vue prête pour les derniers événements et raccourcis de création.</p>
    </section>
  {{/if}}

  {{#if (eq activeTab 'gaia')}}
    <section class="matcore-panel">
      <h2>Gaïa Exploration Tools</h2>
      <p>Vue prête pour biomes, curiosités, ressources et exploration.</p>
    </section>
  {{/if}}
</section>