{
  "id": "gaia-exploration-tools",
  "title": "Gaïa Exploration Tools",
  "description": "Outils d'exploration pour la planète Gaïa : événements, curiosités, biomes et traces de factions.",
  "version": "0.1.0",
  "authors": [
    {
      "name": "Mat"
    }
  ],
  "compatibility": {
    "minimum": "14",
    "verified": "14"
  },

  "relationships": {
    "requires": [
      {
        "id": "lib-foundry-core",
        "type": "module"
      },
      {
        "id": "lib-pf2e-tools",
        "type": "module"
      }
    ],
    "optional": [
      {
        "id": "matcore-system",
        "type": "module"
      }
    ]
  },

  "esmodules": [
    "scripts/main.js"
  ],
  "styles": [
    "styles/gaia-exploration.css"
  ],
  "templates": [
    "templates/gaia-exploration-dialog.hbs",
    "templates/gaia-entry-dialog.hbs",
    "templates/gaia-entry-picker-dialog.hbs"
  ]
}