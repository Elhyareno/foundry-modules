<form class="gaia-entry-picker-form">
  <div class="form-group">
    <label>Type</label>
    <select name="type">
      <option value="">Tous</option>
      {{#each types}}
        <option value="{{this.value}}">{{this.label}}</option>
      {{/each}}
    </select>
  </div>

  <div class="form-group">
    <label>Biome</label>
    <select name="biome">
      <option value="">Tous</option>
      {{#each biomes}}
        <option value="{{this}}">{{this}}</option>
      {{/each}}
    </select>
  </div>

  <div class="form-group">
    <label>Entrée</label>
    <select name="entryKey">
      {{#each entries}}
        <option
          value="{{this.key}}"
          data-type="{{this.type}}"
          data-biome="{{this.biome}}"
        >
          [{{this.typeLabel}}] [{{this.biome}}] {{this.title}}{{#if this.xp}} - {{this.xp}} XP{{/if}}
        </option>
      {{/each}}
    </select>
  </div>

  <div class="form-group">
    <label>
      <input type="checkbox" name="gmOnly">
      Message MJ uniquement
    </label>
  </div>

  <footer class="sheet-footer flexrow">
    <button type="submit">
      Lancer l’entrée
    </button>
  </footer>
</form>