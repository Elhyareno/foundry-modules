<form class="gaia-exploration-form">
  <div class="form-group">
    <label for="gaia-biome">Biome</label>
    <select name="biome" id="gaia-biome">
      {{#each biomes}}
        <option value="{{this}}">{{this}}</option>
      {{/each}}
    </select>
  </div>
  <div class="form-group">
  <label for="gaia-roll-type">Type de tirage</label>
  <select name="rollType" id="gaia-roll-type">
    <option value="event">Événement</option>
    <option value="curiosity">Curiosité</option>
    <option value="resource">Ressource</option>
  </select>
</div>

  <p class="notes">
    Génère un événement d'exploration pour le biome choisi et l'envoie dans le chat.
  </p>
<div class="form-group">
  <label>
    <input type="checkbox" name="gmOnly">
    Message MJ uniquement
  </label>
</div>
  <footer class="sheet-footer flexrow">
  <button type="submit">
    Générer
  </button>
</footer>
</form>