<form class="gaia-entry-form">
  <div class="form-group">
    <label>Type</label>
    <select name="type">
      <option value="event">Événement</option>
      <option value="curiosity">Curiosité</option>
      <option value="resource">Ressource</option>
    </select>
  </div>

  <div class="form-group">
    <label>Biome</label>
    <select name="biome">
      {{#each biomes}}
        <option value="{{this}}">{{this}}</option>
      {{/each}}
    </select>
  </div>

  <div class="form-group">
    <label>Titre</label>
    <input type="text" name="title">
  </div>

  <div class="form-group">
    <label>Description</label>
    <textarea name="description"></textarea>
  </div>

  <div class="form-group">
    <label>Récompense XP</label>
    <select name="xp">
      <option value="0">Aucune</option>
      <option value="10">10 XP</option>
      <option value="20">20 XP</option>
      <option value="30">30 XP</option>
    </select>
  </div>

  <div class="form-group">
    <label>Danger / Valeur</label>
    <input type="number" name="score" value="1">
  </div>

  <div class="form-group">
    <label>Tags</label>
    <input type="text" name="tags" placeholder="essaim, jungle, étrange">
  </div>

  <footer class="sheet-footer flexrow">
    <button type="submit">Ajouter</button>
  </footer>
</form>