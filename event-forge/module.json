{
  "id": "event-forge",
  "title": "Event Forge",
  "description": "Interface custom pour créer des événements avec test de compétence, fluff et log journal.",
  "version": "1.0.0",
  "authors": [{ "name": "Mat" }],
  "compatibility": {
    "minimum": "14",
    "verified": "14"
  },
  "esmodules": [
    "scripts/main.js"
  ],
  "styles": [
    "styles/event-forge.css"
  ],
  "templates": [
    "templates/event-form.hbs"
  ],
  "relationships": {
    "requires": [
      {
        "id": "lib-foundry-core",
        "type": "module"
      },
      {
        "id": "lib-pf2e-tools",
        "type": "module"
      }
    ],
    "optional": [
      {
        "id": "matcore-system",
        "type": "module"
      }
    ]
  }
}