<form class="event-forge-form">
  <div class="form-group">
    <label>Titre</label>
    <input type="text" name="title" required />
  </div>

  <div class="form-group">
    <label>Compétence</label>
    <select name="skill">
      {{#each skills}}
        <option value="{{this.key}}">{{this.label}}</option>
      {{/each}}
    </select>
  </div>

  <div class="form-group">
    <label>DD réel</label>
    <input type="number" name="dc" value="20" required />
  </div>

  <div class="form-group">
    <label>Cacher le DD aux joueurs</label>
    <input type="checkbox" name="hideDc" />
  </div>

  <div class="form-group">
    <label>Difficulté affichée</label>
    <select name="difficultyLabel">
      <option value="Incredibly easy">Incredibly easy (-10)</option>
      <option value="Very easy">Very easy (-5)</option>
      <option value="Easy">Easy (-2)</option>
      <option value="Standard" selected>Standard</option>
      <option value="Hard">Hard (+2)</option>
      <option value="Very hard">Very hard (+5)</option>
      <option value="Incredibly hard">Incredibly hard (+10)</option>
    </select>
  </div>

  <div class="form-group">
    <label>Texte d’ambiance</label>
    <textarea name="fluff" rows="4"></textarea>
  </div>

  <div class="form-group stacked">
    <label>Réussite critique</label>
    <textarea name="criticalSuccess" rows="3"></textarea>
  </div>

  <div class="form-group stacked">
    <label>Réussite</label>
    <textarea name="success" rows="3"></textarea>
  </div>

  <div class="form-group stacked">
    <label>Échec</label>
    <textarea name="failure" rows="3"></textarea>
  </div>

  <div class="form-group stacked">
    <label>Échec critique</label>
    <textarea name="criticalFailure" rows="3"></textarea>
  </div>

  <footer class="sheet-footer flexrow">
    <button type="submit">
      <i class="fas fa-feather"></i>
      Publier l’événement
    </button>
  </footer>
</form>