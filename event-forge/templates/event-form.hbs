<form class="event-forge-form">
  <div class="form-group">
    <label>Titre</label>
    <input type="text" name="title" required />
  </div>

  <div class="form-group">
    <label>Compétence</label>
    <select name="skill">
      {{#each skills}}
        <option value="{{this.key}}">{{this.label}}</option>
      {{/each}}
    </select>
  </div>

  <div class="form-group">
    <label>Niveau de l’événement</label>
    <select name="eventLevel">
      {{#each levels}}
        <option value="{{this.value}}">{{this.label}}</option>
      {{/each}}
    </select>
  </div>

  <div class="form-group">
    <label>Difficulté relative</label>
    <select name="difficultyKey">
      {{#each difficulties}}
        <option value="{{this.key}}">{{this.label}}</option>
      {{/each}}
    </select>
  </div>

  <div class="form-group">
    <label>Cacher le DD aux joueurs</label>
    <input type="checkbox" name="hideDc" checked />
  </div>

  <div class="form-group">
    <label>Texte d’ambiance</label>
    <textarea name="fluff" rows="4"></textarea>
  </div>

  <div class="form-group stacked">
    <label>Réussite critique</label>
    <textarea name="criticalSuccess" rows="3"></textarea>
  </div>

  <div class="form-group stacked">
    <label>Réussite</label>
    <textarea name="success" rows="3"></textarea>
  </div>

  <div class="form-group stacked">
    <label>Échec</label>
    <textarea name="failure" rows="3"></textarea>
  </div>

  <div class="form-group stacked">
    <label>Échec critique</label>
    <textarea name="criticalFailure" rows="3"></textarea>
  </div>

  <footer class="sheet-footer flexrow">
    <button type="submit">
      <i class="fas fa-feather"></i>
      Publier l’événement
    </button>
  </footer>
</form>